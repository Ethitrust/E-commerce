NODE_ENV=development

PORT=4000

MONGODB_URI=mongodb+srv://user:password@cluster.example.mongodb.net/dbname

CORS_ORIGIN=http://localhost:5173



# Phase 1 — JWT (minimum 16 characters each)

JWT_ACCESS_SECRET=change-me-access-secret-min16

JWT_REFRESH_SECRET=change-me-refresh-secret-min16

JWT_ACCESS_EXPIRES=15m

JWT_REFRESH_EXPIRES=7d

REFRESH_COOKIE_NAME=refresh



# Used only by `npm run seed` (same password hashes for demo accounts)

DEV_SEED_PASSWORD=DevPass123!



# Optional — Phase 7 listing images via backend → Cloudinary (all three needed for uploads)

CLOUDINARY_CLOUD_NAME=

CLOUDINARY_API_KEY=

CLOUDINARY_API_SECRET=



# Ethitrust org-escrows (https://api.ethitrust.me)
# When ETHITRUST_API_KEY is set, checkout creates one escrow per seller on the order.

ETHITRUST_API_KEY=

ETHITRUST_BASE_URL=https://api.ethitrust.me

# Optional — verifies X-Signature on POST /api/v1/webhooks/ethitrust
ETHITRUST_WEBHOOK_SECRET=

# Fallback for sellers that have not chosen who pays fees (buyer | seller | split)
ETHITRUST_DEFAULT_WHO_PAYS_FEES=split

